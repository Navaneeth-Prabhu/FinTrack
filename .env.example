# FinTrack — Environment Variables
# Copy to .env and fill in the values.

# ── Supabase (already set) ──────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Google OAuth (NEW — required for Google Sign-In & Sync) ─────────────────
# Create these at: https://console.cloud.google.com → APIs → Credentials
#
# 1. Web client (used both from Expo Go and Supabase token exchange)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com

# 2. Android client (SHA-1 of your release keystore)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxx.apps.googleusercontent.com

# 3. iOS client (only needed for TestFlight / App Store builds)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com

# ── Also configure Supabase ─────────────────────────────────────────────────
# In Supabase Dashboard → Authentication → Providers → Google
#   Client ID = paste your GOOGLE_WEB_CLIENT_ID
#   Client Secret = paste from Google Cloud Console
#   Authorized Redirect URI = https://your-project.supabase.co/auth/v1/callback
